{
    "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
    "name": "ac",
    "description": "Multi-plugin marketplace — structured development partner, git mastery, GitHub CLI, and frontend design skills for Claude Code",
    "owner": {
        "name": "Anilcan Cakir",
        "email": "anilcan.cakir@gmail.com"
    },
    "plugins": [
        {
            "name": "ac",
            "description": "Claude Code setup + creator toolkit plus main-agent planning trio — /ac:plan, /ac:execute, /ac:wisdom, /ac:setup-*, /ac:init-*, /ac:commit commands plus skill-creator, agent-creator, command-creator, rule-creator, and claude-md-writer skills.",
            "version": "6.4.1",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/ac",
            "category": "productivity",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "tags": [
                "setup",
                "creator-skills",
                "claude-md",
                "commit",
                "planning",
                "kodizm-mcp"
            ]
        },
        {
            "name": "github-cli",
            "description": "GitHub CLI skill — gh patterns for issues, PRs, releases, actions, and gh api.",
            "version": "0.1.1",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/github-cli",
            "category": "productivity",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "tags": [
                "github",
                "cli",
                "gh",
                "pull-requests",
                "issues"
            ]
        },
        {
            "name": "github-actions",
            "description": "GitHub Actions workflow generator — CI/CD pipelines, releases, Docker builds, reusable workflows, and security hardening.",
            "version": "0.1.0",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/github-actions",
            "category": "productivity",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "tags": [
                "github-actions",
                "ci-cd",
                "workflows",
                "devops",
                "security"
            ]
        },
        {
            "name": "git-master",
            "description": "Git expert skill — atomic commits with style detection, rebase, and history archaeology.",
            "version": "0.1.1",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/git-master",
            "category": "productivity",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "tags": [
                "git",
                "commits",
                "rebase",
                "atomic-commits",
                "history"
            ]
        },
        {
            "name": "frontend-design",
            "description": "Frontend design skill — production-grade UI for web and mobile with design systems and visual hierarchy.",
            "version": "0.1.1",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/frontend-design",
            "category": "productivity",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "tags": [
                "frontend",
                "design",
                "ui-ux",
                "web-design",
                "mobile-design"
            ]
        },
        {
            "name": "dart-lsp",
            "description": "Dart/Flutter language server — go-to-definition, find references, hover, and real-time diagnostics for Claude Code.",
            "version": "0.1.0",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/dart-lsp",
            "category": "development",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "strict": false,
            "lspServers": {
                "dart": {
                    "command": "dart",
                    "args": ["language-server"],
                    "extensionToLanguage": {
                        ".dart": "dart"
                    }
                }
            },
            "tags": [
                "dart",
                "flutter",
                "lsp",
                "language-server",
                "code-intelligence"
            ]
        },
        {
            "name": "json-lsp",
            "description": "JSON language server — diagnostics, schema validation, and hover for .json and .jsonc files.",
            "version": "0.1.0",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/json-lsp",
            "category": "development",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "strict": false,
            "lspServers": {
                "json": {
                    "command": "vscode-json-languageserver",
                    "args": ["--stdio"],
                    "extensionToLanguage": {
                        ".json": "json",
                        ".jsonc": "jsonc"
                    }
                }
            },
            "tags": [
                "json",
                "jsonc",
                "lsp",
                "language-server",
                "schema-validation"
            ]
        },
        {
            "name": "yaml-lsp",
            "description": "YAML language server — schema validation, hover, and diagnostics for .yaml and .yml files.",
            "version": "0.1.0",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/yaml-lsp",
            "category": "development",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "strict": false,
            "lspServers": {
                "yaml": {
                    "command": "yaml-language-server",
                    "args": ["--stdio"],
                    "extensionToLanguage": {
                        ".yaml": "yaml",
                        ".yml": "yaml"
                    }
                }
            },
            "tags": [
                "yaml",
                "yml",
                "lsp",
                "language-server",
                "schema-validation"
            ]
        },
        {
            "name": "markdown-lsp",
            "description": "Markdown language server (marksman) — go-to-definition for links, find references, and document symbols for .md files.",
            "version": "0.1.0",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/markdown-lsp",
            "category": "development",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "strict": false,
            "lspServers": {
                "markdown": {
                    "command": "marksman",
                    "args": ["server"],
                    "extensionToLanguage": {
                        ".md": "markdown",
                        ".mdx": "markdown"
                    }
                }
            },
            "tags": [
                "markdown",
                "md",
                "lsp",
                "language-server",
                "marksman"
            ]
        },
        {
            "name": "ac-new",
            "description": "Multi-platform prompt renderer with Liquid templates — renders prompt components for Claude Code, OpenCode, Antigravity, and generic platforms.",
            "version": "0.1.0",
            "author": {
                "name": "Anilcan Cakir",
                "email": "anilcan.cakir@gmail.com"
            },
            "source": "./plugins/ac-new",
            "category": "development",
            "homepage": "https://github.com/anilcancakir/claude-code-plugin",
            "tags": [
                "prompt-rendering",
                "liquid-templates",
                "typescript",
                "multi-platform",
                "template-engine"
            ]
        }
    ]
}